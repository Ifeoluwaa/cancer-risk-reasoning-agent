# CRRA Deployment Environment Configuration Template
# Copy this file to .env and fill in appropriate values. Do NOT commit production secrets.

# Port Streamlit binds to (default: 8501)
PORT=8501

# --- Google Cloud Platform Settings ---
# Google Cloud Project ID for deployment
GCP_PROJECT=your-gcp-project-id

# Google Cloud Region for Cloud Run (e.g., us-central1)
GCP_REGION=us-central1

# Google Application Credentials path (for local ADK/GCP emulator testing)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# --- ChromaDB Vector Store Configurations ---
# Persistence directory path for ChromaDB. If left blank, ChromaDB runs in ephemeral (in-memory) mode.
CHROMADB_PERSIST_DIR=/data/chroma_db
